<?xml version="1.0" encoding="UTF-8"?>
<Defs>

    <ThingDef ParentName="ApparelNoQualityBase">
        <defName>OCARINA_Apparel_ScavengerGrenadeBelt</defName>
        <label>scavenger grenade belt</label>
        <description>Near-black spiked grenades created by the scavengers. They can be thrown a surprising distance, exploding almost immediately on contact. Can be reloaded using scavenger grenades.</description>
        <techLevel>Industrial</techLevel>
        <comps>
            <li Class="CompProperties_ApparelReloadable">
                <maxCharges>10</maxCharges>
                <ammoDef>OCARINA_Weapon_ScavengerGrenade</ammoDef>
                <ammoCountToRefill>1</ammoCountToRefill>
                <baseReloadTicks>60</baseReloadTicks>
                <soundReload>Standard_Reload</soundReload>
                <hotKey>Misc4</hotKey>
                <chargeNoun>scavenger</chargeNoun>
                <displayGizmoWhileUndrafted>false</displayGizmoWhileUndrafted>
            </li>
        </comps>
        <verbs>
            <li>
                <label>throw scavenger grenade</label>
                <verbClass>Verb_LaunchProjectileStatic</verbClass>
                <hasStandardCommand>true</hasStandardCommand>
                <onlyManualCast>True</onlyManualCast>
                <range>19.9</range>
                <forcedMissRadius>0.9</forcedMissRadius>
                <warmupTime>1.0</warmupTime>
                <noiseRadius>4</noiseRadius>
                <ai_IsBuildingDestroyer>true</ai_IsBuildingDestroyer>
                <soundCast>ThrowGrenade</soundCast>
                <drawHighlightWithLineOfSight>true</drawHighlightWithLineOfSight>
                <targetParams>
                    <canTargetLocations>true</canTargetLocations>
                </targetParams>
                <defaultProjectile>OCARINA_Proj_ScavengerGrenade</defaultProjectile>
                <rangedFireRulepack>Combat_RangedFire_Thrown</rangedFireRulepack>
            </li>
        </verbs>
        <recipeMaker>
            <unfinishedThingDef>UnfinishedPack</unfinishedThingDef>
            <recipeUsers>
                <li>TableMachining</li>
            </recipeUsers>
            <useIngredientsForColor>false</useIngredientsForColor>
            <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
            <workSkill>Crafting</workSkill>
            <effectWorking>Smith</effectWorking>
            <soundWorking>Recipe_Smith</soundWorking>
            <skillRequirements>
                <Crafting>3</Crafting>
            </skillRequirements>
        </recipeMaker>
        <costList>
            <OCARINA_Weapon_ScavengerGrenade>1</OCARINA_Weapon_ScavengerGrenade>
        </costList>
        <graphicData>
            <texPath>Things/Item/Equipment/WeaponRanged/ScavengerGrenadeBelt</texPath>
            <graphicClass>Graphic_Single</graphicClass>
        </graphicData>
        <tickerType>Normal</tickerType>
        <statBases>
            <WorkToMake>500</WorkToMake>
            <Mass>3</Mass>
            <Flammability>0.4</Flammability>
            <EquipDelay>2</EquipDelay>
        </statBases>
        <thingCategories>
            <li>ApparelUtility</li>
        </thingCategories>
        <generateAllowChance>0.05</generateAllowChance>
        <apparel>
            <wornGraphicPath>Things/Pawn/Humanlike/Apparel/ScavengerGrenadeBelt/ScavengerGrenadeBelt</wornGraphicPath>
            <wornGraphicData>
                <renderUtilityAsPack>true</renderUtilityAsPack>
                <north>
                    <offset>(-0.30,-0.25)</offset>
                    <hulk>
                        <offset>(-0.0,-0.15)</offset>
                    </hulk>
                    <fat>
                        <offset>(-0.0,-0.0)</offset>
                    </fat>
                    <thin>
                        <offset>(0.10,-0.0)</offset>
                    </thin>
                </north>
                <south>
                    <offset>(0.25,-0.20)</offset>
                    <hulk>
                        <offset>(-0.0,-0.10)</offset>
                    </hulk>
                    <fat>
                        <offset>(-0.0,-0.0)</offset>
                    </fat>
                    <thin>
                        <offset>(-0.10,-0.0)</offset>
                    </thin>
                </south>
                <east>
                    <offset>(-0.15,-0.25)</offset>
                    <hulk>
                        <offset>(-0.0,-0.15)</offset>
                    </hulk>
                    <fat>
                        <offset>(-0.10,-0.10)</offset>
                    </fat>
                </east>
                <west>
                    <offset>(0.15,-0.25)</offset>
                    <hulk>
                        <offset>(-0.0,-0.15)</offset>
                    </hulk>
                    <fat>
                        <offset>(-0.0,-0.10)</offset>
                    </fat>
                </west>
                <male>
                    <scale>(0.75,0.75)</scale>
                </male>
                <female>
                    <scale>(0.75,0.75)</scale>
                </female>
                <thin>
                    <scale>(0.7,0.7)</scale>
                </thin>
                <hulk>
                    <scale>(0.9,0.9)</scale>
                </hulk>
                <fat>
                    <scale>(0.9,0.9)</scale>
                </fat>
            </wornGraphicData>
            <careIfWornByCorpse>false</careIfWornByCorpse>
            <careIfDamaged>false</careIfDamaged>
            <wearPerDay>0</wearPerDay>
            <bodyPartGroups>
                <li>Waist</li>
            </bodyPartGroups>
            <layers>
                <li>Belt</li>
            </layers>
            <tags>
                <!-- <li>GrenadeDestructiveBelt</li> -->
                <li>OCARINA_ScavengerGrenadeBelt</li>
                <li>OCARINA_Scavenger</li>
            </tags>
        </apparel>
    </ThingDef>

</Defs>