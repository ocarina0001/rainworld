<?xml version="1.0" encoding="UTF-8"?>
<Defs>

    <!-- it's the scarlands stuff but like x5 -->

    <StructureLayoutDef>
        <defName>OCARINA_OutskirtRuins</defName>
        <workerClass>LayoutWorker_AncientRuins</workerClass>
        <wallStuffDef>Steel</wallStuffDef>
        <doorStuffDef>Steel</doorStuffDef>
        <exteriorDoorStuffDef>Steel</exteriorDoorStuffDef>
        <shouldDamage>true</shouldDamage>
        <canHaveMultipleLayoutsInRoom>true</canHaveMultipleLayoutsInRoom>
        <multipleLayoutRoomChance>1</multipleLayoutRoomChance>
        <minRoomWidth>30</minRoomWidth>
        <minRoomHeight>30</minRoomHeight>
        <roomDefs>
            <OCARINA_EmptyRoomOutskirts>25</OCARINA_EmptyRoomOutskirts>
        </roomDefs>
        <junkScaterrers>
            <RubblePile>
                <groupsPerHundredCells>1~3</groupsPerHundredCells>
                <itemsPerGroup>2~4</itemsPerGroup>
                <groupDistRange>3~5</groupDistRange>
            </RubblePile>
            <Filth_RubbleRock>
                <groupsPerHundredCells>1~3</groupsPerHundredCells>
                <itemsPerGroup>3~8</itemsPerGroup>
                <groupDistRange>3~5</groupDistRange>
            </Filth_RubbleRock>
        </junkScaterrers>
    </StructureLayoutDef>

</Defs>