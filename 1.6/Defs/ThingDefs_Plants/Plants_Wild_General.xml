<?xml version="1.0" encoding="UTF-8"?>
<Defs>

    <ThingDef ParentName="PlantBase">
        <defName>OCARINA_Plant_BatflyGrass</defName>
        <label>batfly grass</label>
        <description>Batfly grass. Houses and spawns batflies, little flying insect pests that are simply another link in the food chain.</description>
        <thingClass>RainWorld.Plant_BatflyGrass</thingClass>
        <statBases>
            <MaxHitPoints>85</MaxHitPoints>
            <Flammability>1.3</Flammability>
            <Nutrition>0.60</Nutrition>
        </statBases>
        <graphicData>
            <texPath>Things/Plant/BatflyGrass</texPath>
            <graphicClass>Graphic_Random</graphicClass>
        </graphicData>
        <hideAtSnowOrSandDepth>0.5</hideAtSnowOrSandDepth>
        <receivesSignals>true</receivesSignals>
        <selectable>true</selectable>
        <tickerType>Normal</tickerType>
        <ingestible />
        <plant>
            <fertilityMin>0.05</fertilityMin>
            <fertilitySensitivity>0.3</fertilitySensitivity>
            <growDays>0.5</growDays>
            <leaflessGraphicPath>Things/Plant/BatflyGrass_Leafless</leaflessGraphicPath>
            <harvestWork>70</harvestWork>
            <visualSizeRange>1~1.4</visualSizeRange>
            <topWindExposure>0.4</topWindExposure>
            <wildOrder>8</wildOrder>
            <maxGrowthTemperature>75</maxGrowthTemperature>
        </plant>
        <comps>
            <li Class="CompProperties_CanBeDormant">
                <startsDormant>true</startsDormant>
                <canWakeUpFogged>false</canWakeUpFogged>
            </li>
            <li Class="CompProperties_WakeUpDormant" />
            <li Class="CompProperties_SpawnerPawn">
                <spawnablePawnKinds>
                    <li>OCARINA_Batfly</li>
                </spawnablePawnKinds>
                <lordJob>LordJob_DefendAndExpandHive</lordJob>
                <spawnSound>Hive_Spawn</spawnSound>
                <initialPawnsPoints>1</initialPawnsPoints>
                <maxSpawnedPawnsPoints>2</maxSpawnedPawnsPoints>
                <lordJoinRadius>10</lordJoinRadius>
            </li>
        </comps>
    </ThingDef>

</Defs>